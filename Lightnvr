#!/bin/bash
# Pastikan skrip dijalankan sebagai root/sudo
[ "$EUID" -ne 0 ] && { echo "Jalankan dengan sudo!"; exit 1; }

echo "===================================================="
echo "Memulai Instalasi LightNVR pada Armbian Server..."
echo "===================================================="

# 1. Update sistem dan instal dependensi
echo "[1/4] Memperbarui sistem dan menginstal dependensi..."
apt-get update && apt-get upgrade -y
apt-get install -y build-essential cmake pkg-config git \
  libsqlite3-dev libavcodec-dev libavformat-dev libavutil-dev \
  libswscale-dev libuv1-dev libcurl4-openssl-dev libmbedtls-dev \
  curl wget

# 2. Kloning repositori dan inisialisasi submodule
echo "[2/4] Mengunduh kode sumber LightNVR..."
cd /opt
[ -d "lightnvr" ] && rm -rf lightnvr
git clone https://github.com/opensensor/lightnvr.git
cd lightnvr
git submodule update --init --recursive

# 3. Kompilasi dan Instalasi
echo "[3/4] Mengompilasi dan menginstal LightNVR..."
./scripts/build.sh --release
./scripts/install.sh

# 4. Konfigurasi Layanan Systemd
echo "[4/4] Mengaktifkan layanan..."
systemctl daemon-reload
systemctl enable lightnvr
systemctl start lightnvr

echo "===================================================="
echo "Instalasi Selesai!"
echo "Akses: http://ALAMAT-IP-ARMBIAN:8080"
echo "Status: sudo systemctl status lightnvr"
echo "Konfigurasi: /etc/lightnvr/lightnvr.ini"
echo "===================================================="
