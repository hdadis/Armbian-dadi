#!/bin/bash

# Pastikan script dijalankan sebagai root (administrator)
if [ "$EUID" -ne 0 ]; then
  echo "Harap jalankan script ini sebagai root (gunakan sudo)"
  exit 1
fi

echo "Menginstal aplikasi..."
# Ganti dengan paket yang ingin Anda install, contoh:
sudo apt update
sudo apt-get install ntfsprogs
sudo apt-get install ntfs-3g
sudo ntfsfix /dev/sda1
sudo gedit fstab
mkdir /mnt/External
mount /dev/sda1 /mnt/External
nano /etc/fstab
UUID="EAFE72BDFE72819D" /mnt/External    ntfs-3g   defaults,nofail,noatime  0  2
UUID="6CFC6F3FFC6F02A6" /mnt/External    ntfs-3g   defaults,nofail,noatime  0  2
sudo systemctl daemon-reload
sudo mount -a

echo "Instalasi selesai!"
