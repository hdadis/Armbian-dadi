#!/bin/bash

# Pastikan script dijalankan sebagai root (administrator)
if [ "$EUID" -ne 0 ]; then
  echo "Harap jalankan script ini sebagai root (gunakan sudo)"
  exit 1
fi

echo "Menginstal aplikasi..."
# Ganti dengan paket yang ingin Anda install, contoh:
sudo apt install mpd
sudo nano /etc/mpd.conf
#UNDER THE AUDIO OUTPUT#
audio_output {
    type            "alsa"  # or "pulse" depending on your setup
    name            "432Hz Output"
    auto_resample   "no"
    
    # Enable SoX and apply the pitch shift
    # You can specify quality parameters if needed (e.g., -v -b 24)
    format          "44100:16:2"
    mixer_type      "software"
    
    # Use SoX for the pitch adjustment
    # Note: Modern MPD versions require the sox plugin
    # Alternatively, you can use the SoundTouch library if available in your build
}

# Define the resampler using SoX
resampler {
    plugin          "sox"
    quality         "high"
    # Additional SoX parameters can go here
}
sudo systemctl restart mpd
sudo nano /etc/pulse/daemon.conf
default-sample-format = s24le
default-sample-rate = 192000
resample-method = soxr-vhq
pulseaudio -k && pulseaudio -D

echo "Instalasi selesai!"
