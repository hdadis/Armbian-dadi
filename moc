bash#!/bin/bash

# Pastikan script dijalankan sebagai root (administrator)
if [ "$EUID" -ne 0 ]; then
  echo "Harap jalankan script ini sebagai root (gunakan sudo)"
  exit 1
fi

echo "Memperbarui daftar paket..."
apt update -y

echo "Menginstal aplikasi..."
# Ganti dengan paket yang ingin Anda install, contoh:
sudo apt install moc moc-ffmpeg-plugin -y
sudo apt install alsa-utils -y
sudo usermod -a -G audio $USER
alsamixer
sudo apt install pulseaudio pulseaudio-utils -y
sudo usermod -a -G pulse-access $USER

echo "Instalasi selesai!"
