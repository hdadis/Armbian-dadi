#!/bin/bash
# Pastikan skrip dijalankan sebagai root/sudo
[ "$EUID" -ne 0 ] && { echo "Jalankan skrip ini dengan sudo!"; exit 1; }

echo "===================================================="
echo "Memulai Instalasi LightNVR via Docker Compose..."
echo "===================================================="

# 1. Update sistem dan install Docker Engine & Compose plugin
echo "[1/4] Memeriksa dan menginstal Docker..."
apt-get update && apt-get install -y curl gnupg lsb-release

if ! command -v docker &> /dev/null; then
    echo "Mengunduh dan menginstal Docker secara otomatis..."
    curl -fsSL https://docker.com | sh
fi

# 2. Buat direktori kerja untuk LightNVR
echo "[2/4] Menyiapkan folder konfigurasi..."
mkdir -p /opt/lightnvr/config
mkdir -p /opt/lightnvr/data
cd /opt/lightnvr

# 3. Buat file docker-compose.yml
echo "[3/4] Membuat file docker-compose.yml..."
cat << 'EOF' > docker-compose.yml
version: '3.8'

services:
  lightnvr:
    image: opensensor/lightnvr:latest
    container_name: lightnvr
    restart: always
    network_mode: host
    volumes:
      - ./config:/etc/lightnvr
      - ./data:/var/lib/lightnvr
      - /etc/localtime:/etc/localtime:ro
    environment:
      - TZ=Asia/Jakarta
EOF

# 4. Jalankan kontainer Docker
echo "[4/4] Menjalankan LightNVR di latar belakang..."
docker compose up -d

echo "===================================================="
echo "Instalasi Berhasil!"
echo "Akses web UI di: http://ALAMAT-IP-ARMBIAN:8080"
echo "Folder konfigurasi: /opt/lightnvr/config"
echo "Folder data/rekaman: /opt/lightnvr/data"
echo "Cek status kontainer: sudo docker ps"
echo "===================================================="
